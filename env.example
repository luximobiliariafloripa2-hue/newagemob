# AGEMOB — variáveis de ambiente
# Copie este arquivo para .env para rodar localmente

# Porta (o Render define automaticamente — não altere em produção)
PORT=3000

# URL pública do sistema — OBRIGATÓRIO no Render
# Substitua pelo seu endereço real após o primeiro deploy
# Exemplo: https://agemob.onrender.com
BASE_URL=https://SEU-APP.onrender.com
